<?xml version="1.0" encoding="utf-8"?>
<!--
    item_history_row.xml
    Place in: res/layout/item_history_row.xml
    Inflated by HistoryActivity for each dose log entry.
    Status badge colour is set in Java: green=Taken, orange=Skipped, grey=Delayed
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginBottom="4dp">

    <!-- Pill icon with light green circular background -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/card_pill_bg"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_centerVertical="true"
        app:cardBackgroundColor="#EAF6EE"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_pill"
            android:contentDescription="Pill" />
    </androidx.cardview.widget.CardView>

    <!-- Pill name + time -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/card_pill_bg"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <!-- tv_pill_name: set in HistoryActivity -->
        <TextView
            android:id="@+id/tv_pill_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aspirin"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- tv_pill_time: set in HistoryActivity -->
        <TextView
            android:id="@+id/tv_pill_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8:00 AM"
            android:textColor="#999999"
            android:textSize="12sp"
            android:layout_marginTop="3dp" />
    </LinearLayout>

    <!-- Status badge: "Taken" / "Skipped" / "Delayed" -->
    <!-- Background colour set in Java based on status -->
    <TextView
        android:id="@+id/tv_status_badge"
        android:layout_width="90dp"
        android:layout_height="34dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="@drawable/btn_green_rounded"
        android:gravity="center"
        android:text="Taken"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

</RelativeLayout>